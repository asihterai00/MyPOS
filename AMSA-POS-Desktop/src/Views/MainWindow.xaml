<mah:MetroWindow x:Class="AMSA.POS.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AMSA.POS.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryDarkBrush}"
        GlowBrush="{StaticResource AccentBrush}">

    <mah:MetroWindow.DataContext>
        <vm:MainWindowViewModel />
    </mah:MetroWindow.DataContext>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <TextBlock Text="{Binding CurrentDateTime, StringFormat={}{0:dd MMM yyyy - HH:mm:ss}}" 
                       Foreground="{StaticResource TextMutedBrush}" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0" />
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryDarkBrush}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <TextBlock Text="🏪 AMSA POS" 
                               Style="{StaticResource Heading1}" 
                               FontWeight="Bold" />
                    <TextBlock Text="Point of Sale System" 
                               Style="{StaticResource MutedText}" 
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Spacing="4">
                    <Button Content="🛒 Point of Sale" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="POS" />
                    
                    <Button Content="📦 Inventory" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="Inventory" />
                    
                    <Button Content="📋 Purchase Orders" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="PurchaseOrders" />
                    
                    <Button Content="🏷️ Categories" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="Categories" />
                    
                    <Button Content="👥 Customers" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="Customers" />
                    
                    <Button Content="🚚 Vendors" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="Vendors" />
                    
                    <Button Content="📊 Sales History" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="SalesHistory" />
                    
                    <Button Content="📈 Reports" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="Reports" />
                    
                    <Button Content="👤 Users" 
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding SetViewCommand}"
                            CommandParameter="Users" />
                </StackPanel>

                <!-- User Info -->
                <Border Grid.Row="2" 
                        Background="{StaticResource PrimaryDarkBrush}" 
                        CornerRadius="8" 
                        Padding="12"
                        Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="👨‍💼 Admin" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Administrator" 
                                   Style="{StaticResource MutedText}" 
                                   FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Point of Sale" 
                           Style="{StaticResource Heading1}" 
                           Margin="0,0,0,8" />
                <TextBlock Text="Process transactions quickly and efficiently" 
                           Style="{StaticResource MutedText}" />
            </StackPanel>

            <!-- POS View Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="400" />
                </Grid.ColumnDefinitions>

                <!-- Products Grid -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search & Filter -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="🔍 Search products..." />

                        <Button Grid.Column="1" 
                                Content="Search" 
                                Style="{StaticResource ModernButton}" 
                                Margin="12,0,0,0"
                                Command="{Binding SearchProductsCommand}" />
                    </Grid>

                    <!-- Category Filter -->
                    <ItemsControl Grid.Row="1" 
                                  ItemsSource="{Binding Categories}" 
                                  Margin="0,0,0,16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" 
                                        Style="{StaticResource SecondaryButton}" 
                                        Margin="0,0,8,8"
                                        Padding="16,8" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Products List -->
                    <ScrollViewer Grid.Row="2" 
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Products}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ModernCard}" 
                                            Width="180"
                                            Cursor="Hand">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="100" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Product Image Placeholder -->
                                            <Border Grid.Row="0" 
                                                    Background="{StaticResource PrimaryDarkBrush}" 
                                                    CornerRadius="8"
                                                    Margin="0,0,0,12">
                                                <TextBlock Text="📦" 
                                                           FontSize="48" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Product Name -->
                                            <TextBlock Grid.Row="1" 
                                                       Text="{Binding Name}" 
                                                       FontWeight="SemiBold" 
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4" />

                                            <!-- Stock Info -->
                                            <TextBlock Grid.Row="2" 
                                                       Text="{Binding Stock, StringFormat=Stock: {0}}" 
                                                       Style="{StaticResource MutedText}" 
                                                       FontSize="12"
                                                       Margin="0,0,0,8" />

                                            <!-- Price & Add Button -->
                                            <Grid Grid.Row="3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Price, StringFormat='Rp {0:N0}'}" 
                                                           Style="{StaticResource PriceDisplay}" 
                                                           VerticalAlignment="Center" />

                                                <Button Grid.Column="1" 
                                                        Content="+" 
                                                        Width="32" 
                                                        Height="32" 
                                                        Style="{StaticResource SuccessButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="16" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Cart Panel -->
                <Border Grid.Column="1" 
                        Background="{StaticResource SecondaryDarkBrush}" 
                        CornerRadius="12" 
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Cart Header -->
                        <TextBlock Grid.Row="0" 
                                   Text="🛒 Shopping Cart" 
                                   Style="{StaticResource Heading2}" 
                                   Margin="0,0,0,16" />

                        <!-- Cart Items -->
                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding CartLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PrimaryDarkBrush}" 
                                                CornerRadius="8" 
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ProductName}" 
                                                               FontWeight="SemiBold" 
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Price, StringFormat='Rp {0:N0}'}" 
                                                               Style="{StaticResource MutedText}" 
                                                               FontSize="12" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" 
                                                            Orientation="Horizontal" 
                                                            VerticalAlignment="Center"
                                                            Margin="12,0,12,0">
                                                    <TextBlock Text="{Binding Quantity}" 
                                                               VerticalAlignment="Center"
                                                               MinWidth="20"
                                                               TextAlignment="Center" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Total, StringFormat='Rp {0:N0}'}" 
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Summary -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,16">
                            <Grid Margin="0,4">
                                <TextBlock Text="Subtotal" Style="{StaticResource BodyText}" />
                                <TextBlock Text="{Binding Subtotal, StringFormat='Rp {0:N0}'}" 
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,4">
                                <TextBlock Text="Tax (11%)" Style="{StaticResource BodyText}" />
                                <TextBlock Text="{Binding Tax, StringFormat='Rp {0:N0}'}" 
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <Border BorderThickness="0,1,0,0" 
                                    BorderBrush="{StaticResource TextMutedBrush}" 
                                    Margin="0,8" />
                            <Grid>
                                <TextBlock Text="Total" FontWeight="Bold" />
                                <TextBlock Text="{Binding Total, StringFormat='Rp {0:N0}'}" 
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource PriceDisplay}" />
                            </Grid>
                        </StackPanel>

                        <!-- Status Message -->
                        <TextBlock Grid.Row="3" 
                                   Text="{Binding StatusMessage}" 
                                   Style="{StaticResource MutedText}" 
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="4" Spacing="8">
                            <Button Content="💳 Process Payment" 
                                    Style="{StaticResource SuccessButton}"
                                    Command="{Binding ProcessSaleCommand}"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}" />
                            
                            <Button Content="🗑️ Clear Cart" 
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ClearCartCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</mah:MetroWindow>
